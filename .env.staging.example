# IFM staging env — copy to /opt/ifm/.env on the VPS and fill in real values.
# NEVER commit the real .env (gitignored). This template is safe to commit.

POSTGRES_USER=ifm
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ifm

# Strong random secret — MUST NOT start with "dev_only" (the API refuses to boot
# in production with a dev placeholder). Generate e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_strong_random_secret

# Host port nginx (web) listens on. Open this in the VPS firewall.
WEB_PORT=8095

# CORS allowlist — REQUIRED before prod. Comma-separated browser origins allowed to call
# the API. Set to the deployed web host (scheme + host + optional port), e.g.
# WEB_ORIGIN=https://farm.example.com
WEB_ORIGIN=https://CHANGE_ME.example.com

# OTP pepper — REQUIRED in production (boot fails on the dev placeholder).
# Generate e.g.: openssl rand -base64 48
OTP_PEPPER=CHANGE_ME_strong_random_pepper

# SMTP (OTP email delivery). Leave SMTP_HOST empty to disable real mail (codes are then
# only logged outside production — users cannot receive OTPs, so set this for staging/prod).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IFM <no-reply@CHANGE_ME.example.com>"
