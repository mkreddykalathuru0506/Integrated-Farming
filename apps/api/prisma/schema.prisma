// IFM — Phase 0 schema (owner-approved 2026-06-22).
// Money is integer paise (BigInt). Every tenant entity carries farmId + audit columns + soft-delete.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  VETERINARIAN
  ACCOUNTANT
  LABOUR
  BUYER
}

enum UnitType {
  POULTRY
  CATTLE
  GOATERY
  RABBITRY
  MUSHROOM_HOUSE
  HATCHERY
  FROZEN_STORE
  NURSERY
  BIOGAS
  OTHER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum FssaiTier {
  BASIC
  STATE
  CENTRAL
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String? @unique
  name         String
  passwordHash String
  locale       String  @default("en")
  isActive     Boolean @default(true)

  memberships   Membership[]
  refreshTokens RefreshToken[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Farm {
  id       String  @id @default(cuid())
  name     String
  state    String?
  district String?

  settings        FarmSetting?
  units           Unit[]
  memberships     Membership[]
  species         Species[]
  breeds          Breed[]
  lifecycleStages LifecycleStage[]
  batches         Batch[]
  animals         Animal[]
  movements       Movement[]
  mortalityEvents MortalityEvent[]
  workers           Worker[]
  attendance        Attendance[]
  scheduleTemplates ScheduleTemplate[]
  tasks             Task[]
  dailyLogs         DailyLog[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model FarmSetting {
  id     String @id @default(cuid())
  farmId String @unique
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  timezone      String @default("Asia/Kolkata")
  currency      String @default("INR")
  defaultLocale String @default("en")
  areaUnit      String @default("acre")

  // Compliance placeholders (configurable per farm; never hard-coded) — open decision #8
  fssaiLicenseNo    String?
  fssaiTier         FssaiTier?
  gstin             String?
  gstThresholdPaise BigInt? // money as integer paise; a setting, not hard-coded

  extra Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id       String   @id @default(cuid())
  farmId   String
  farm     Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name     String
  type     UnitType
  code     String?
  isActive Boolean  @default(true)

  batches Batch[]
  animals Animal[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, name])
  @@index([farmId])
}

model Membership {
  id     String           @id @default(cuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmId String
  farm   Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  role   Role
  status MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, farmId]) // one role per user per farm in Phase 0
  @@index([farmId])
}

model AuditLog {
  id       String  @id @default(cuid())
  farmId   String? // null = global/system action
  userId   String?
  action   String // e.g. "farm.create", "user.login"
  entity   String
  entityId String?
  before   Json?
  after    Json?
  ip       String?

  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ---------- Livestock reference (Phase 1) ----------
enum TrackingMode {
  INDIVIDUAL
  BATCH
}

model Species {
  id              String       @id @default(cuid())
  farmId          String
  farm            Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  code            String
  name            String
  trackingMode    TrackingMode
  isSystemDefault Boolean      @default(false)

  breeds  Breed[]
  stages  LifecycleStage[]
  batches Batch[]
  animals Animal[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, code])
  @@index([farmId])
}

model Breed {
  id              String  @id @default(cuid())
  farmId          String
  farm            Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId       String
  species         Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  name            String
  isSystemDefault Boolean @default(false)

  batches Batch[]
  animals Animal[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, speciesId, name])
  @@index([speciesId])
}

model LifecycleStage {
  id              String  @id @default(cuid())
  farmId          String
  farm            Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId       String
  species         Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  name            String
  sequence        Int
  isTerminal      Boolean @default(false)
  isSystemDefault Boolean @default(false)

  batches Batch[] @relation("BatchStage")
  animals Animal[] @relation("AnimalStage")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, speciesId, name])
  @@index([speciesId])
}

// ---------- Livestock core (Phase 1) ----------
enum BatchStatus {
  ACTIVE
  CLOSED
}

model Batch {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  breedId   String?
  breed     Breed?  @relation(fields: [breedId], references: [id])

  code String
  name String?

  currentStageId String?
  currentStage   LifecycleStage? @relation("BatchStage", fields: [currentStageId], references: [id])

  initialCount Int
  currentCount Int
  status       BatchStatus @default(ACTIVE)
  acquiredAt   DateTime?
  source       String?
  qrCode       String?     @unique

  movements       Movement[]
  mortalityEvents MortalityEvent[]
  dailyLogs       DailyLog[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, code])
  @@index([farmId])
  @@index([speciesId])
  @@index([unitId])
}

enum AnimalStatus {
  ACTIVE
  SOLD
  DEAD
  CULLED
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

model Animal {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  unitId String?
  unit   Unit?  @relation(fields: [unitId], references: [id])

  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  breedId   String?
  breed     Breed?  @relation(fields: [breedId], references: [id])

  tagNumber String?
  qrCode    String?   @unique
  name      String?
  sex       Sex       @default(UNKNOWN)
  dob       DateTime?

  currentStageId String?
  currentStage   LifecycleStage? @relation("AnimalStage", fields: [currentStageId], references: [id])
  status         AnimalStatus    @default(ACTIVE)

  movements       Movement[]
  mortalityEvents MortalityEvent[]
  dailyLogs       DailyLog[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, tagNumber])
  @@index([farmId])
  @@index([speciesId])
  @@index([unitId])
}

enum EventType {
  MORTALITY
  CULL
}

model Movement {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  fromUnitId String?
  toUnitId   String?
  count      Int?
  reason     String?
  movedAt    DateTime @default(now())

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([animalId])
  @@index([batchId])
}

model MortalityEvent {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  type       EventType
  count      Int       @default(1)
  cause      String?
  occurredAt DateTime  @default(now())
  notes      String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([batchId])
  @@index([animalId])
}

// ---------- Daily ops (Phase 2) ----------
enum WageType {
  DAILY
  PIECE_RATE
  MONTHLY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

model Worker {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  userId             String? // optional link to a login User
  name               String
  phone              String?
  designation        String?
  wageType           WageType @default(DAILY)
  dailyWageRatePaise BigInt? // money = integer paise
  isActive           Boolean  @default(true)

  attendances Attendance[]
  tasks       Task[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([farmId])
}

model Attendance {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  workerId String
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  date   DateTime
  status AttendanceStatus @default(PRESENT)
  notes  String?

  recordedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([workerId, date])
  @@index([farmId])
}

enum TaskType {
  FEEDING
  CLEANING
  EGG_COLLECTION
  HEALTH_CHECK
  WEIGHING
  TEMPERATURE_LOG
  OTHER
}

enum TaskStatus {
  PENDING
  DONE
  MISSED
  SKIPPED
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

model ScheduleTemplate {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name             String
  taskType         TaskType
  unitId           String?
  frequency        Frequency
  timeOfDay        String? // "06:00"
  assignedWorkerId String?
  isActive         Boolean   @default(true)

  tasks Task[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([farmId])
}

model Task {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  templateId String?
  template   ScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  title    String
  taskType TaskType
  unitId   String?
  dueDate  DateTime
  status   TaskStatus @default(PENDING)

  assignedWorkerId String?
  assignedWorker   Worker? @relation(fields: [assignedWorkerId], references: [id])

  completedAt DateTime?
  completedBy String?
  notes       String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, dueDate])
  @@index([farmId])
  @@index([dueDate])
  @@index([status])
}

enum LogType {
  FEED
  EGGS
  WEIGHT
}

model DailyLog {
  id     String  @id @default(cuid())
  farmId String
  farm   Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  type   LogType

  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])
  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  unitId   String?

  quantity Int
  unit     String
  loggedAt DateTime @default(now())
  notes    String?

  clientLogId String? @unique // idempotency key for offline sync
  recordedBy  String?
  createdAt   DateTime @default(now())

  @@index([farmId])
  @@index([type])
}
