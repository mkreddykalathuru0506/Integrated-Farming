// IFM — Phase 0 schema (owner-approved 2026-06-22).
// Money is integer paise (BigInt). Every tenant entity carries farmId + audit columns + soft-delete.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  VETERINARIAN
  ACCOUNTANT
  LABOUR
  BUYER
}

enum UnitType {
  POULTRY
  CATTLE
  GOATERY
  RABBITRY
  MUSHROOM_HOUSE
  HATCHERY
  FROZEN_STORE
  NURSERY
  BIOGAS
  OTHER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum FssaiTier {
  BASIC
  STATE
  CENTRAL
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String? @unique
  name         String
  passwordHash String
  locale       String  @default("en")
  isActive     Boolean @default(true)

  memberships   Membership[]
  refreshTokens RefreshToken[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Farm {
  id       String  @id @default(cuid())
  name     String
  state    String?
  district String?

  settings        FarmSetting?
  units           Unit[]
  memberships     Membership[]
  species         Species[]
  breeds          Breed[]
  lifecycleStages LifecycleStage[]
  batches         Batch[]
  animals         Animal[]
  movements       Movement[]
  mortalityEvents MortalityEvent[]
  workers           Worker[]
  attendance        Attendance[]
  scheduleTemplates ScheduleTemplate[]
  tasks             Task[]
  dailyLogs         DailyLog[]
  healthRecords     HealthRecord[]
  medicationLogs    MedicationLog[]
  vaccinationItems  VaccinationScheduleItem[]
  vaccinationEvents VaccinationEvent[]
  breedingRecords   BreedingRecord[]
  hatcheryBatches   HatcheryBatch[]
  incubationLogs    IncubationLog[]
  feedItems         FeedItem[]
  feedTransactions  FeedTransaction[]
  expenses          Expense[]
  loans             Loan[]
  insurances        Insurance[]
  vendors           Vendor[]
  customers         Customer[]
  invoices          Invoice[]
  salesOrders       SalesOrder[]
  coldStorages      ColdStorage[]
  temperatureLogs   TemperatureLog[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model FarmSetting {
  id     String @id @default(cuid())
  farmId String @unique
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  timezone      String @default("Asia/Kolkata")
  currency      String @default("INR")
  defaultLocale String @default("en")
  areaUnit      String @default("acre")

  // Compliance placeholders (configurable per farm; never hard-coded) — open decision #8
  fssaiLicenseNo    String?
  fssaiTier         FssaiTier?
  gstin             String?
  gstThresholdPaise BigInt? // money as integer paise; a setting, not hard-coded

  extra Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id       String   @id @default(cuid())
  farmId   String
  farm     Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name     String
  type     UnitType
  code     String?
  isActive Boolean  @default(true)

  batches Batch[]
  animals Animal[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, name])
  @@index([farmId])
}

model Membership {
  id     String           @id @default(cuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmId String
  farm   Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  role   Role
  status MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, farmId]) // one role per user per farm in Phase 0
  @@index([farmId])
}

model AuditLog {
  id       String  @id @default(cuid())
  farmId   String? // null = global/system action
  userId   String?
  action   String // e.g. "farm.create", "user.login"
  entity   String
  entityId String?
  before   Json?
  after    Json?
  ip       String?

  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ---------- Livestock reference (Phase 1) ----------
enum TrackingMode {
  INDIVIDUAL
  BATCH
}

model Species {
  id              String       @id @default(cuid())
  farmId          String
  farm            Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  code            String
  name            String
  trackingMode    TrackingMode
  isSystemDefault Boolean      @default(false)
  gestationDays   Int?
  incubationDays  Int?

  breeds           Breed[]
  stages           LifecycleStage[]
  batches          Batch[]
  animals          Animal[]
  vaccinationItems VaccinationScheduleItem[]
  breedingRecords  BreedingRecord[]
  hatcheryBatches  HatcheryBatch[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, code])
  @@index([farmId])
}

model Breed {
  id              String  @id @default(cuid())
  farmId          String
  farm            Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId       String
  species         Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  name            String
  isSystemDefault Boolean @default(false)

  batches         Batch[]
  animals         Animal[]
  hatcheryBatches HatcheryBatch[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, speciesId, name])
  @@index([speciesId])
}

model LifecycleStage {
  id              String  @id @default(cuid())
  farmId          String
  farm            Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId       String
  species         Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  name            String
  sequence        Int
  isTerminal      Boolean @default(false)
  isSystemDefault Boolean @default(false)

  batches Batch[] @relation("BatchStage")
  animals Animal[] @relation("AnimalStage")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, speciesId, name])
  @@index([speciesId])
}

// ---------- Livestock core (Phase 1) ----------
enum BatchStatus {
  ACTIVE
  CLOSED
}

model Batch {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  breedId   String?
  breed     Breed?  @relation(fields: [breedId], references: [id])

  code String
  name String?

  currentStageId String?
  currentStage   LifecycleStage? @relation("BatchStage", fields: [currentStageId], references: [id])

  initialCount Int
  currentCount Int
  status       BatchStatus @default(ACTIVE)
  acquiredAt   DateTime?
  source       String?
  qrCode       String?     @unique

  movements       Movement[]
  mortalityEvents MortalityEvent[]
  dailyLogs         DailyLog[]
  healthRecords     HealthRecord[]
  medicationLogs    MedicationLog[]
  vaccinationEvents VaccinationEvent[]

  saleReadyAt DateTime?
  expenses    Expense[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, code])
  @@index([farmId])
  @@index([speciesId])
  @@index([unitId])
}

enum AnimalStatus {
  ACTIVE
  SOLD
  DEAD
  CULLED
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

model Animal {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  unitId String?
  unit   Unit?  @relation(fields: [unitId], references: [id])

  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  breedId   String?
  breed     Breed?  @relation(fields: [breedId], references: [id])

  tagNumber String?
  qrCode    String?   @unique
  name      String?
  sex       Sex       @default(UNKNOWN)
  dob       DateTime?

  currentStageId String?
  currentStage   LifecycleStage? @relation("AnimalStage", fields: [currentStageId], references: [id])
  status         AnimalStatus    @default(ACTIVE)

  movements       Movement[]
  mortalityEvents MortalityEvent[]
  dailyLogs         DailyLog[]
  healthRecords     HealthRecord[]
  medicationLogs    MedicationLog[]
  vaccinationEvents VaccinationEvent[]
  breedingsAsDam    BreedingRecord[] @relation("DamBreeding")
  breedingsAsSire   BreedingRecord[] @relation("SireBreeding")

  saleReadyAt DateTime?

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, tagNumber])
  @@index([farmId])
  @@index([speciesId])
  @@index([unitId])
}

enum EventType {
  MORTALITY
  CULL
}

model Movement {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  fromUnitId String?
  toUnitId   String?
  count      Int?
  reason     String?
  movedAt    DateTime @default(now())

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([animalId])
  @@index([batchId])
}

model MortalityEvent {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  type       EventType
  count      Int       @default(1)
  cause      String?
  occurredAt DateTime  @default(now())
  notes      String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([batchId])
  @@index([animalId])
}

// ---------- Daily ops (Phase 2) ----------
enum WageType {
  DAILY
  PIECE_RATE
  MONTHLY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

model Worker {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  userId             String? // optional link to a login User
  name               String
  phone              String?
  designation        String?
  wageType           WageType @default(DAILY)
  dailyWageRatePaise BigInt? // money = integer paise
  isActive           Boolean  @default(true)

  attendances Attendance[]
  tasks       Task[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([farmId])
}

model Attendance {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  workerId String
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  date   DateTime
  status AttendanceStatus @default(PRESENT)
  notes  String?

  recordedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([workerId, date])
  @@index([farmId])
}

enum TaskType {
  FEEDING
  CLEANING
  EGG_COLLECTION
  HEALTH_CHECK
  WEIGHING
  TEMPERATURE_LOG
  OTHER
}

enum TaskStatus {
  PENDING
  DONE
  MISSED
  SKIPPED
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

model ScheduleTemplate {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name             String
  taskType         TaskType
  unitId           String?
  frequency        Frequency
  timeOfDay        String? // "06:00"
  assignedWorkerId String?
  isActive         Boolean   @default(true)

  tasks Task[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([farmId])
}

model Task {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  templateId String?
  template   ScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  title    String
  taskType TaskType
  unitId   String?
  dueDate  DateTime
  status   TaskStatus @default(PENDING)

  assignedWorkerId String?
  assignedWorker   Worker? @relation(fields: [assignedWorkerId], references: [id])

  completedAt DateTime?
  completedBy String?
  notes       String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, dueDate])
  @@index([farmId])
  @@index([dueDate])
  @@index([status])
}

enum LogType {
  FEED
  EGGS
  WEIGHT
}

model DailyLog {
  id     String  @id @default(cuid())
  farmId String
  farm   Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  type   LogType

  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])
  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  unitId   String?

  quantity Int
  unit     String
  loggedAt DateTime @default(now())
  notes    String?

  clientLogId String? @unique // idempotency key for offline sync
  recordedBy  String?
  createdAt   DateTime @default(now())

  @@index([farmId])
  @@index([type])
}

// ---------- Health & breeding (Phase 3) ----------
enum HealthEventType {
  CHECKUP
  SYMPTOM
  TREATMENT
  VET_VISIT
  VACCINATION
  DEWORMING
}

model HealthRecord {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  type        HealthEventType
  occurredAt  DateTime        @default(now())
  description String?
  vetName     String?
  diagnosis   String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([animalId])
  @@index([batchId])
}

model MedicationLog {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  drugName        String
  dose            String?
  route           String?
  administeredAt  DateTime @default(now())
  withdrawalDays  Int
  withdrawalUntil DateTime // = administeredAt + withdrawalDays

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([withdrawalUntil])
}

model VaccinationScheduleItem {
  id          String          @id @default(cuid())
  farmId      String
  farm        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId   String
  species     Species         @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  vaccineName String
  type        HealthEventType @default(VACCINATION)
  ageDays     Int
  isSystemDefault Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([farmId, speciesId, vaccineName, ageDays])
  @@index([speciesId])
}

model VaccinationEvent {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String?
  animal   Animal? @relation(fields: [animalId], references: [id])
  batchId  String?
  batch    Batch?  @relation(fields: [batchId], references: [id])

  vaccineName    String
  administeredAt DateTime @default(now())
  scheduleItemId String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([batchId])
}

enum BreedingStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  FAILED
}

model BreedingRecord {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  speciesId String?
  species   Species? @relation(fields: [speciesId], references: [id])
  damId     String?
  dam       Animal?  @relation("DamBreeding", fields: [damId], references: [id])
  sireId    String?
  sire      Animal?  @relation("SireBreeding", fields: [sireId], references: [id])

  method          String?
  breedingDate    DateTime
  expectedDueDate DateTime?
  status          BreedingStatus @default(PLANNED)
  offspringCount  Int?
  notes           String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId])
}

enum HatchStatus {
  SET
  INCUBATING
  CANDLED
  LOCKDOWN
  HATCHED
  CLOSED
}

enum IncubationEventType {
  CANDLING
  LOCKDOWN
  HATCH
  TEMP_LOG
  TURN
  OTHER
}

model HatcheryBatch {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  breedId   String?
  breed     Breed?  @relation(fields: [breedId], references: [id])

  code              String
  setDate           DateTime
  eggCount          Int
  incubationDays    Int
  expectedHatchDate DateTime
  candlingDate      DateTime?
  lockdownDate      DateTime?
  status            HatchStatus @default(SET)
  fertileCount      Int?
  hatchedCount      Int?

  incubationLogs IncubationLog[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, code])
  @@index([farmId])
}

model IncubationLog {
  id              String        @id @default(cuid())
  farmId          String
  farm            Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  hatcheryBatchId String
  hatcheryBatch   HatcheryBatch @relation(fields: [hatcheryBatchId], references: [id], onDelete: Cascade)

  occurredAt   DateTime            @default(now())
  event        IncubationEventType
  temperatureC Float?
  humidityPct  Float?
  notes        String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([hatcheryBatchId])
}

// ---------- Feed & finance (Phase 4) ----------
enum FeedTxnType {
  PURCHASE
  CONSUMPTION
}

model FeedItem {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name               String
  unit               String   @default("kg")
  stockQty           Decimal  @default(0)
  reorderThreshold   Decimal?
  lastUnitPricePaise BigInt?

  transactions FeedTransaction[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, name])
  @@index([farmId])
}

model FeedTransaction {
  id         String      @id @default(cuid())
  farmId     String
  farm       Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  feedItemId String
  feedItem   FeedItem    @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  type       FeedTxnType

  qty            Decimal
  unitPricePaise BigInt?
  totalPaise     BigInt?
  batchId        String? // consumption → attribute cost to a batch
  vendorId       String?
  occurredAt     DateTime @default(now())

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([feedItemId])
  @@index([batchId])
}

enum ExpenseCategory {
  FEED
  LABOUR
  MEDICINE
  UTILITIES
  MAINTENANCE
  CAPITAL
  OTHER
}

model Expense {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  category    ExpenseCategory
  amountPaise BigInt
  occurredAt  DateTime        @default(now())
  description String?
  batchId     String?
  batch       Batch?          @relation(fields: [batchId], references: [id])
  unitId      String?
  vendorId    String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([farmId])
  @@index([batchId])
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

enum InsuranceType {
  LIVESTOCK
  ASSET
  CROP
  OTHER
}

enum InsuranceStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  CANCELLED
}

model Loan {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  lender          String
  principalPaise  BigInt
  emiAmountPaise  BigInt?
  interestRateBps Int?
  tenureMonths    Int?
  startDate       DateTime
  nextDueDate     DateTime?
  status          LoanStatus @default(ACTIVE)
  notes           String?

  payments LoanPayment[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([farmId])
}

model LoanPayment {
  id     String @id @default(cuid())
  farmId String
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  amountPaise BigInt
  paidAt      DateTime @default(now())

  createdBy String?
  createdAt DateTime @default(now())

  @@index([loanId])
}

model Insurance {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  provider        String
  policyNumber    String?
  type            InsuranceType
  premiumPaise    BigInt
  sumInsuredPaise BigInt?
  startDate       DateTime
  endDate         DateTime
  status          InsuranceStatus @default(ACTIVE)
  notes           String?

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([farmId])
}

// ---------- Invoicing (Phase 4) ----------
enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model Vendor {
  id     String  @id @default(cuid())
  farmId String
  farm   Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name   String
  gstin  String?
  phone  String?

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, name])
  @@index([farmId])
}

model Customer {
  id      String  @id @default(cuid())
  farmId  String
  farm    Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name    String
  gstin   String?
  phone   String?
  state   String?
  address String?

  invoices    Invoice[]
  salesOrders SalesOrder[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, name])
  @@index([farmId])
}

model Invoice {
  id            String        @id @default(cuid())
  farmId        String
  farm          Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  invoiceNumber String
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  issueDate     DateTime      @default(now())
  status        InvoiceStatus @default(ISSUED)

  subtotalPaise BigInt
  cgstPaise     BigInt
  sgstPaise     BigInt
  igstPaise     BigInt
  totalPaise    BigInt

  fssaiLicenseNo     String?
  placeOfSupplyState String?
  notes              String?

  lines InvoiceLineItem[]

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, invoiceNumber])
  @@index([farmId])
}

model InvoiceLineItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description    String
  hsnSac         String?
  qty            Decimal
  unitPricePaise BigInt
  gstRateBps     Int
  taxablePaise   BigInt
  gstPaise       BigInt
  lineTotalPaise BigInt
  batchId        String?

  @@index([invoiceId])
  @@index([batchId])
}

// ---------- Sales & frozen meat (Phase 5) ----------
enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(cuid())
  farmId      String
  farm        Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  orderNumber String
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id])
  status      SalesOrderStatus @default(DRAFT)
  orderDate   DateTime         @default(now())
  expectedDate DateTime?
  totalPaise  BigInt           @default(0)
  notes       String?

  lines SalesOrderLine[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, orderNumber])
  @@index([farmId])
  @@index([customerId])
  @@index([status])
}

model SalesOrderLine {
  id      String     @id @default(cuid())
  orderId String
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  description    String
  qty            Decimal
  unit           String  @default("kg")
  unitPricePaise BigInt
  lineTotalPaise BigInt
  batchId        String? // direct-from-batch sale (live)
  productLotId   String? // processed-lot sale (Phase 5.3+)

  @@index([orderId])
  @@index([batchId])
}

// Cold-chain product state (§6: fresh 0–7°C, frozen ≤ −18°C). Reused by ProductLot (5.3).
enum ProductState {
  FRESH
  FROZEN
}

model ColdStorage {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name     String
  unitId   String?
  mode     ProductState @default(FROZEN)
  minTempC Float        @default(-30)
  maxTempC Float        @default(-18)
  isActive Boolean      @default(true)

  temperatureLogs TemperatureLog[]

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([farmId, name])
  @@index([farmId])
}

model TemperatureLog {
  id            String      @id @default(cuid())
  farmId        String
  farm          Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  coldStorageId String
  coldStorage   ColdStorage @relation(fields: [coldStorageId], references: [id], onDelete: Cascade)

  recordedAt   DateTime @default(now())
  temperatureC Float
  isOutOfRange Boolean  @default(false)
  source       String? // "manual" | "sensor"
  notes        String?

  recordedBy String?
  createdAt  DateTime @default(now())

  @@index([farmId])
  @@index([coldStorageId])
  @@index([recordedAt])
}
