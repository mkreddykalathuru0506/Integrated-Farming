# Copy to .env and fill in. NEVER commit real secrets.
NODE_ENV=development

# --- API ---
API_PORT=4000

# --- PostgreSQL (used by Prisma + docker compose) ---
POSTGRES_USER=ifm
POSTGRES_PASSWORD=ifm_dev_password
POSTGRES_DB=ifm
# Host ports — override if these are taken on your machine (then update the URLs below to match).
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ifm:ifm_dev_password@localhost:5432/ifm?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Web ---
VITE_API_URL=http://localhost:4000

# --- CORS ---
# Comma-separated allowlist of browser origins permitted to call the API.
# Leave empty in dev (permissive). REQUIRED before prod — set to the web host, e.g.
# WEB_ORIGIN=https://farm.example.com
WEB_ORIGIN=

# --- Auth (placeholders; wired in slice 0.2) ---
JWT_ACCESS_SECRET=dev_only_change_me_access
JWT_REFRESH_SECRET=dev_only_change_me_refresh

# --- OTP login / password reset (slice 11.3) ---
# HMAC pepper for hashing one-time codes. Any long random string; REQUIRED in production
# (the API refuses to boot in production with the dev placeholder).
OTP_PEPPER=dev-pepper

# --- SMTP (OTP email delivery) ---
# Leave SMTP_HOST empty in dev/CI — no real mail is sent and the code is logged to the
# API console instead. Set all of these to deliver real email.
SMTP_HOST=
SMTP_PORT=587
# 'true' = TLS-on-connect (port 465); anything else = STARTTLS on 587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IFM <no-reply@ifm.local>"
