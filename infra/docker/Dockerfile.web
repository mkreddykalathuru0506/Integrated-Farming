# IFM Web — Vite build via pnpm workspaces, served by nginx. Build context = repo root.
############################
# Stage 1: build
############################
FROM node:22-alpine AS build
WORKDIR /workspace
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc tsconfig.base.json ./
COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

RUN pnpm install --frozen-lockfile --filter @ifm/web... || pnpm install --filter @ifm/web...
# Empty API base → the SPA calls relative /api/*, which nginx proxies to the api
# container (same-origin). Type-check runs in CI; here we just emit the bundle.
ENV VITE_API_URL=""
RUN pnpm --filter @ifm/web exec vite build

############################
# Stage 2: nginx runtime
############################
FROM nginx:1.27-alpine
COPY infra/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/apps/web/dist /usr/share/nginx/html
EXPOSE 80
# BusyBox wget resolves localhost→::1 first; nginx binds IPv4 only → use 127.0.0.1.
HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=10s \
    CMD wget -q -O - http://127.0.0.1/healthz || exit 1
CMD ["nginx", "-g", "daemon off;"]
